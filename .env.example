# ==============================
# Application
# ==============================

APP_NAME=hospital-api
APP_ENV=development
APP_PORT=8080

# ==============================
# Database (PostgreSQL)
# ==============================

DB_HOST=postgres
DB_PORT=5432
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hospital_db
# DATABASE_DSN is a convenient way to specify the entire connection string in one variable. It can override the individual DB_* variables if set.
DATABASE_DSN=postgres://postgres:postgres@postgres:5432/hospital_db?sslmode=disable

# ==============================
# JWT
# ==============================

JWT_SECRET=super-secret-key-change-this
JWT_EXPIRATION_DAYS=30

# ==============================
# Logging
# ==============================

LOG_LEVEL=info
LOG_FORMAT=json

# ==============================
# Rate Limiting (Optional / Nice to Have)
# ==============================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60